# Server binding
HOST=0.0.0.0
PORT=3000
NODE_ENV=production

# CORS / socket origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Enable CSP once assets are CSP-clean (0/1)
ENABLE_CSP=0

# Optional: session duration in hours
SESSION_TTL_HOURS=12

# Optional log/backup retention overrides
LOG_RETENTION_DAYS=14
BACKUP_RETENTION_DAYS=30

# API Security - Require API keys for certain endpoints (comma-separated tokens)
# Generate strong random tokens using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to disable API key requirement (not recommended for production)
API_KEYS=

# API Security - IP whitelist for API access (comma-separated IPs or CIDR blocks)
# Examples: 192.168.1.0/24,10.0.0.5
# Leave empty to allow all IPs (default)
ALLOWED_API_IPS=

# OAuth / OIDC Authentication
# These settings can also be configured via the admin interface
# Leave empty to configure through admin UI or to disable external authentication

# Google OAuth (for Google Workspace)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Generic OIDC Provider
# Examples: Entra ID (Azure AD), Keycloak, Auth0, Okta
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:3000/auth/oidc/callback
