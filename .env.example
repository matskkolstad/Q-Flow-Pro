# Server binding
HOST=0.0.0.0
PORT=3000
NODE_ENV=production

# CORS / socket origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Enable CSP once assets are CSP-clean (0/1)
ENABLE_CSP=0

# Optional: session duration in hours
SESSION_TTL_HOURS=12

# Optional log/backup retention overrides
LOG_RETENTION_DAYS=14
BACKUP_RETENTION_DAYS=30
